<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VELA Admin Panel</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Outfit',sans-serif;background:#0a0f1e;color:#e2e8f0;min-height:100vh;}
a{text-decoration:none;color:inherit;}
button{font-family:'Outfit',sans-serif;cursor:pointer;border:none;outline:none;}
input,textarea,select{font-family:'Outfit',sans-serif;outline:none;border:none;background:none;}

/* LOGIN */
#login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0a0f1e 0%,#0d1a35 100%);}
.login-card{background:#111827;border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:40px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,0.5);}
.login-logo{text-align:center;margin-bottom:28px;}
.login-logo img{height:70px;width:auto;mix-blend-mode:screen;}
.login-logo h2{font-size:20px;font-weight:700;color:white;margin-top:8px;}
.login-logo p{font-size:12px;color:#64748b;}
.field{margin-bottom:14px;}
.field label{display:block;font-size:12px;font-weight:500;color:#94a3b8;margin-bottom:6px;}
.field input{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:11px 14px;font-size:14px;color:white;transition:0.2s;}
.field input:focus{border-color:#3b82f6;background:rgba(255,255,255,0.09);}
.btn-login{width:100%;background:linear-gradient(135deg,#1B3A6B,#2a5298);color:white;padding:13px;border-radius:8px;font-size:15px;font-weight:600;margin-top:6px;transition:0.2s;box-shadow:0 4px 14px rgba(27,58,107,0.4);}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(27,58,107,0.5);}
.login-err{font-size:12px;color:#f87171;background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.2);border-radius:6px;padding:9px 12px;margin-bottom:12px;display:none;}

/* APP */
#app{display:none;height:100vh;overflow:hidden;}
#app.visible{display:flex;}

/* SIDEBAR */
.sidebar{width:220px;background:#111827;border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;flex-shrink:0;}
.sidebar-header{padding:20px 16px;border-bottom:1px solid rgba(255,255,255,0.06);}
.sidebar-brand{display:flex;align-items:center;gap:10px;margin-bottom:4px;}
.sidebar-brand img{height:28px;width:auto;mix-blend-mode:screen;}
.sidebar-brand span{font-size:13px;font-weight:600;color:white;}
.sidebar-subtitle{font-size:10px;color:#475569;padding-left:38px;}
.nav{padding:12px 8px;flex:1;overflow-y:auto;}
.nav-section{font-size:9px;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:1px;padding:10px 10px 4px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:8px;cursor:pointer;color:#64748b;font-size:13px;font-weight:400;margin-bottom:1px;transition:0.15s;}
.nav-item:hover{background:rgba(255,255,255,0.05);color:#94a3b8;}
.nav-item.active{background:rgba(59,130,246,0.15);color:#60a5fa;font-weight:500;}
.nav-item .icon{font-size:15px;width:20px;text-align:center;}
.sidebar-footer{padding:12px 8px;border-top:1px solid rgba(255,255,255,0.06);}
.btn-logout{width:100%;display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:8px;font-size:13px;color:#475569;background:none;transition:0.15s;}
.btn-logout:hover{background:rgba(239,68,68,0.1);color:#f87171;}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:#0f172a;}
.topbar{height:58px;background:#111827;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;padding:0 24px;gap:12px;flex-shrink:0;}
.topbar-title{font-size:16px;font-weight:600;color:white;flex:1;}
.topbar-user{font-size:12px;color:#64748b;display:flex;align-items:center;gap:6px;}
.topbar-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#1B3A6B,#C4622D);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:white;}
.content{flex:1;overflow-y:auto;padding:24px;}
.page{display:none;}
.page.active{display:block;animation:fadeIn 0.2s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* CARDS */
.card{background:#1e293b;border:1px solid rgba(255,255,255,0.06);border-radius:14px;overflow:hidden;margin-bottom:20px;}
.card-header{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:14px;font-weight:600;color:#e2e8f0;}
.card-body{padding:16px 20px;}

/* STAT GRID */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
@media(max-width:900px){.stat-grid{grid-template-columns:repeat(2,1fr);}}
.stat-card{background:#1e293b;border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:20px;}
.stat-card .val{font-size:28px;font-weight:800;margin-bottom:4px;}
.stat-card .lbl{font-size:12px;color:#64748b;}
.stat-card .sub{font-size:11px;margin-top:6px;}
.green{color:#34d399;} .blue{color:#60a5fa;} .orange{color:#fb923c;} .purple{color:#a78bfa;}

/* TABLE */
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
th{font-size:11px;font-weight:600;color:#475569;text-align:left;padding:10px 14px;border-bottom:1px solid rgba(255,255,255,0.06);text-transform:uppercase;letter-spacing:0.5px;}
td{font-size:13px;color:#cbd5e1;padding:11px 14px;border-bottom:1px solid rgba(255,255,255,0.04);}
tr:hover td{background:rgba(255,255,255,0.02);}
.badge{font-size:10px;font-weight:600;padding:3px 8px;border-radius:20px;}
.badge-free{background:rgba(100,116,139,0.2);color:#94a3b8;}
.badge-pro{background:rgba(251,146,60,0.15);color:#fb923c;}
.badge-premium{background:rgba(59,130,246,0.15);color:#60a5fa;}
.badge-admin{background:rgba(167,139,250,0.15);color:#a78bfa;}
.badge-active{background:rgba(52,211,153,0.15);color:#34d399;}

/* FORMS */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:600px){.form-grid{grid-template-columns:1fr;}}
.f{display:flex;flex-direction:column;gap:5px;}
.f label{font-size:11px;font-weight:500;color:#64748b;}
.f input,.f select,.f textarea{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:10px 12px;font-size:13px;color:#e2e8f0;transition:0.2s;width:100%;}
.f input:focus,.f select:focus,.f textarea:focus{border-color:#3b82f6;background:rgba(59,130,246,0.08);}
.f textarea{resize:vertical;min-height:80px;}
.f select option{background:#1e293b;}
.btn-primary{background:linear-gradient(135deg,#1B3A6B,#2a5298);color:white;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;transition:0.2s;}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(27,58,107,0.4);}
.btn-danger{background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.2);padding:6px 12px;border-radius:6px;font-size:12px;transition:0.2s;}
.btn-danger:hover{background:rgba(239,68,68,0.25);}
.btn-sm{background:rgba(59,130,246,0.15);color:#60a5fa;border:1px solid rgba(59,130,246,0.2);padding:4px 10px;border-radius:5px;font-size:11px;transition:0.2s;margin-right:4px;}
.btn-sm:hover{background:rgba(59,130,246,0.25);}
.btn-orange{background:rgba(251,146,60,0.15);color:#fb923c;border:1px solid rgba(251,146,60,0.2);padding:4px 10px;border-radius:5px;font-size:11px;transition:0.2s;}
.btn-orange:hover{background:rgba(251,146,60,0.25);}

/* TOAST */
.toast-container{position:fixed;bottom:24px;right:24px;z-index:999;display:flex;flex-direction:column;gap:8px;}
.toast{background:#1e293b;border:1px solid rgba(255,255,255,0.08);color:#e2e8f0;padding:12px 16px;border-radius:8px;font-size:13px;box-shadow:0 8px 30px rgba(0,0,0,0.4);animation:toastIn 0.3s ease;max-width:320px;}
.toast.success{border-color:rgba(52,211,153,0.3);color:#34d399;}
.toast.error{border-color:rgba(248,113,113,0.3);color:#f87171;}
@keyframes toastIn{from{transform:translateX(100%);opacity:0;}to{transform:translateX(0);opacity:1;}}

/* LOADING */
.loading{display:flex;align-items:center;justify-content:center;padding:40px;color:#475569;font-size:14px;gap:8px;}
.spin{width:16px;height:16px;border:2px solid rgba(255,255,255,0.1);border-top-color:#60a5fa;border-radius:50%;animation:spin 0.7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* CHARTS */
.bar-chart{display:flex;flex-direction:column;gap:10px;}
.bar-row{display:flex;align-items:center;gap:10px;}
.bar-label{font-size:12px;color:#94a3b8;width:80px;text-align:right;flex-shrink:0;}
.bar-track{flex:1;background:rgba(255,255,255,0.05);border-radius:99px;height:8px;overflow:hidden;}
.bar-fill{height:100%;border-radius:99px;transition:width 0.6s ease;}
.bar-val{font-size:12px;color:#64748b;width:40px;flex-shrink:0;}

/* SEARCH */
.search-box{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:9px 14px;font-size:13px;color:#e2e8f0;width:220px;}
.search-box:focus{border-color:#3b82f6;outline:none;background:rgba(59,130,246,0.08);}
.search-box::placeholder{color:#475569;}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">
      <img src="data:image/png;base64," alt="VELA">
      <h2>Admin Panel</h2>
      <p>VELA — Run Your Life</p>
    </div>
    <div class="login-err" id="login-err"></div>
    <div class="field">
      <label>Admin Email</label>
      <input type="email" id="admin-email" placeholder="admin@grassion.com" autocomplete="email">
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" id="admin-pass" placeholder="••••••••" autocomplete="current-password">
    </div>
    <button class="btn-login" onclick="doLogin()">Sign In to Admin</button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-brand">
        <img src="data:image/png;base64," alt="VELA">
        <span>VELA Admin</span>
      </div>
      <div class="sidebar-subtitle">Control Panel</div>
    </div>
    <nav class="nav">
      <div class="nav-section">Overview</div>
      <div class="nav-item active" onclick="showPage('dashboard',this)"><span class="icon">📊</span> Dashboard</div>
      <div class="nav-item" onclick="showPage('users',this)"><span class="icon">👥</span> Users</div>
      <div class="nav-section">Management</div>
      <div class="nav-item" onclick="showPage('plans',this)"><span class="icon">💳</span> Plans & Revenue</div>
      <div class="nav-item" onclick="showPage('notifications',this)"><span class="icon">🔔</span> Notifications</div>
      <div class="nav-section">System</div>
      <div class="nav-item" onclick="showPage('settings',this)"><span class="icon">⚙️</span> Settings</div>
    </nav>
    <div class="sidebar-footer">
      <div style="padding:8px 10px;margin-bottom:4px;background:rgba(167,139,250,0.08);border-radius:8px;border:1px solid rgba(167,139,250,0.15);">
        <div style="font-size:10px;color:#a78bfa;font-weight:600;margin-bottom:2px;">ADMIN</div>
        <div style="font-size:12px;color:#94a3b8;" id="sidebar-email">—</div>
      </div>
      <button class="btn-logout" onclick="doLogout()">
        <span>↪</span> Sign Out
      </button>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="topbar-title" id="page-title">Dashboard</div>
      <button onclick="loadAll()" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);color:#94a3b8;padding:6px 14px;border-radius:6px;font-size:12px;cursor:pointer;font-family:Outfit,sans-serif;">↻ Refresh</button>
      <div class="topbar-user">
        <div class="topbar-avatar" id="topbar-avatar">A</div>
        <span id="topbar-email">Admin</span>
      </div>
    </div>
    <div class="content">

      <!-- DASHBOARD -->
      <div class="page active" id="page-dashboard">
        <div class="stat-grid" id="stat-grid">
          <div class="stat-card"><div class="loading"><div class="spin"></div> Loading...</div></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="card">
            <div class="card-header"><span class="card-title">Plan Distribution</span></div>
            <div class="card-body" id="plan-chart"><div class="loading"><div class="spin"></div></div></div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Recent Signups</span></div>
            <div class="card-body" id="recent-signups"><div class="loading"><div class="spin"></div></div></div>
          </div>
        </div>
      </div>

      <!-- USERS -->
      <div class="page" id="page-users">
        <div class="card">
          <div class="card-header">
            <span class="card-title">All Users</span>
            <input type="text" class="search-box" placeholder="Search by name or email..." oninput="filterUsers(this.value)" id="user-search">
          </div>
          <div class="card-body table-wrap">
            <table>
              <thead><tr><th>Name</th><th>Email</th><th>Plan</th><th>Role</th><th>Joined</th><th>Actions</th></tr></thead>
              <tbody id="users-table"><tr><td colspan="6" class="loading"><div class="spin"></div> Loading...</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- PLANS -->
      <div class="page" id="page-plans">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="card">
            <div class="card-header"><span class="card-title">Grant Plan to User</span></div>
            <div class="card-body">
              <div class="form-grid" style="grid-template-columns:1fr;">
                <div class="f"><label>User Email</label><input type="email" id="grant-email" placeholder="user@example.com"></div>
                <div class="f"><label>Plan</label>
                  <select id="grant-plan">
                    <option value="free">Free</option>
                    <option value="pro">Pro (₹199/mo)</option>
                    <option value="premium">Premium (₹499/mo)</option>
                  </select>
                </div>
                <button class="btn-primary" onclick="grantPlan()" style="margin-top:6px;">Grant Plan</button>
              </div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Revenue Overview</span></div>
            <div class="card-body" id="revenue-overview"><div class="loading"><div class="spin"></div></div></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Pro & Premium Users</span></div>
          <div class="card-body table-wrap">
            <table>
              <thead><tr><th>Name</th><th>Email</th><th>Plan</th><th>Joined</th><th>Actions</th></tr></thead>
              <tbody id="paying-users-table"><tr><td colspan="5" class="loading"><div class="spin"></div></td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- NOTIFICATIONS -->
      <div class="page" id="page-notifications">
        <div class="card" style="max-width:600px;">
          <div class="card-header"><span class="card-title">Send Broadcast Notification</span></div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:14px;">
              <div class="f"><label>Notification Title</label><input type="text" id="notif-title" placeholder="e.g. New Feature Alert!"></div>
              <div class="f"><label>Message</label><textarea id="notif-body" placeholder="Write your message..."></textarea></div>
              <div class="f"><label>Target Users</label>
                <select id="notif-target">
                  <option value="all">All Users</option>
                  <option value="pro">Pro Users Only</option>
                  <option value="premium">Premium Users Only</option>
                  <option value="free">Free Users Only</option>
                </select>
              </div>
              <button class="btn-primary" onclick="sendNotif()">Send Notification</button>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Notification History</span></div>
          <div class="card-body table-wrap">
            <table>
              <thead><tr><th>Title</th><th>Message</th><th>Target</th><th>Status</th><th>Sent</th></tr></thead>
              <tbody id="notif-history"><tr><td colspan="5" class="loading"><div class="spin"></div></td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SETTINGS -->
      <div class="page" id="page-settings">
        <div class="card" style="max-width:500px;">
          <div class="card-header"><span class="card-title">Admin Access Management</span></div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:14px;">
              <div class="f"><label>Grant Admin Role to Email</label><input type="email" id="make-admin-email" placeholder="user@example.com"></div>
              <div class="f"><label>Role</label>
                <select id="make-admin-role">
                  <option value="admin">Admin</option>
                  <option value="super_admin">Super Admin</option>
                  <option value="user">Remove Admin (set to user)</option>
                </select>
              </div>
              <button class="btn-primary" onclick="grantAdmin()">Update Role</button>
            </div>
          </div>
        </div>
        <div class="card" style="max-width:500px;">
          <div class="card-header"><span class="card-title">System Info</span></div>
          <div class="card-body" id="system-info"><div class="loading"><div class="spin"></div></div></div>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="toast-container" id="toast-container"></div>

<script>
// ============================================================
// CONFIG — point to your backend
// ============================================================
const API = 'https://vela.grassion.com'; // Railway backend URL
// For local testing: const API = 'http://localhost:3000';

const SUPABASE_URL  = 'https://rhvwtvzaujxmerqkhdlv.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJodnd0dnphdWp4bWVycWtoZGx2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyODIzODQsImV4cCI6MjA4OTg1ODM4NH0.DcXWtKKRpi1HqFdBPVfTkyaMjkbPd8-_z2owo5ArA4U';

let currentSession = null;
let allUsers = [];

// ============================================================
// AUTH
// ============================================================
async function doLogin() {
  const email = document.getElementById('admin-email').value.trim();
  const pass  = document.getElementById('admin-pass').value;
  const errEl = document.getElementById('login-err');
  errEl.style.display = 'none';

  if (!email || !pass) { errEl.textContent = 'Enter email and password'; errEl.style.display = 'block'; return; }

  // Sign in via Supabase directly
  const r = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=password`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_ANON },
    body: JSON.stringify({ email, password: pass })
  });
  const data = await r.json();

  if (!r.ok || !data.access_token) {
    errEl.textContent = data.error_description || data.msg || 'Invalid credentials';
    errEl.style.display = 'block';
    return;
  }

  // Check admin role
  const profileR = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${data.user.id}&select=role,full_name,email`, {
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${data.access_token}` }
  });
  const profiles = await profileR.json();
  const profile = profiles[0];

  if (!profile || !['admin','super_admin'].includes(profile.role)) {
    errEl.textContent = 'Access denied. You are not an admin.';
    errEl.style.display = 'block';
    await fetch(`${SUPABASE_URL}/auth/v1/logout`, { method: 'POST', headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${data.access_token}` } });
    return;
  }

  currentSession = data;
  localStorage.setItem('vela_admin_session', JSON.stringify(data));

  document.getElementById('sidebar-email').textContent = profile.email || email;
  document.getElementById('topbar-email').textContent = profile.full_name || email;
  document.getElementById('topbar-avatar').textContent = (profile.full_name || email).charAt(0).toUpperCase();

  document.getElementById('login-screen').style.display = 'none';
  const appEl = document.getElementById('app');
  appEl.style.display = 'flex';

  await loadAll();
}

async function doLogout() {
  if (currentSession) {
    await fetch(`${SUPABASE_URL}/auth/v1/logout`, { method: 'POST', headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${currentSession.access_token}` } });
  }
  currentSession = null;
  localStorage.removeItem('vela_admin_session');
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('admin-pass').value = '';
}

// Check existing session on load
async function checkSession() {
  const saved = localStorage.getItem('vela_admin_session');
  if (!saved) return;
  try {
    const data = JSON.parse(saved);
    // Verify token still valid
    const r = await fetch(`${SUPABASE_URL}/auth/v1/user`, { headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${data.access_token}` } });
    if (!r.ok) { localStorage.removeItem('vela_admin_session'); return; }
    const profileR = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${data.user.id}&select=role,full_name,email`, { headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${data.access_token}` } });
    const profiles = await profileR.json();
    if (!profiles[0] || !['admin','super_admin'].includes(profiles[0].role)) { localStorage.removeItem('vela_admin_session'); return; }
    currentSession = data;
    document.getElementById('sidebar-email').textContent = profiles[0].email;
    document.getElementById('topbar-email').textContent = profiles[0].full_name || profiles[0].email;
    document.getElementById('topbar-avatar').textContent = (profiles[0].full_name || profiles[0].email).charAt(0).toUpperCase();
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    await loadAll();
  } catch(e) { localStorage.removeItem('vela_admin_session'); }
}

// ============================================================
// DATA LOADING
// ============================================================
async function sbGet(table, query='') {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${table}?${query}`, {
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${currentSession.access_token}` }
  });
  return r.json();
}

async function sbUpdate(table, id, data) {
  await fetch(`${SUPABASE_URL}/rest/v1/${table}?id=eq.${id}`, {
    method: 'PATCH',
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${currentSession.access_token}`, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
    body: JSON.stringify(data)
  });
}

async function sbUpdateWhere(table, col, val, data) {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${table}?${col}=eq.${encodeURIComponent(val)}`, {
    method: 'PATCH',
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${currentSession.access_token}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' },
    body: JSON.stringify(data)
  });
  return r.json();
}

async function sbInsert(table, data) {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${table}`, {
    method: 'POST',
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${currentSession.access_token}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' },
    body: JSON.stringify(data)
  });
  return r.json();
}

async function loadAll() {
  await loadDashboard();
  await loadUsers();
  await loadNotifHistory();
  await loadSystemInfo();
}

async function loadDashboard() {
  const users = await sbGet('profiles', 'select=*&order=created_at.desc');
  if (!Array.isArray(users)) { console.error('Failed to load users:', users); return; }
  allUsers = users;

  const total = users.length;
  const pro = users.filter(u => u.plan === 'pro').length;
  const premium = users.filter(u => u.plan === 'premium').length;
  const free = total - pro - premium;
  const revenue = (pro * 199) + (premium * 499);

  document.getElementById('stat-grid').innerHTML = `
    <div class="stat-card"><div class="val green">₹${revenue.toLocaleString('en-IN')}</div><div class="lbl">Est. Revenue / Month</div><div class="sub" style="color:#475569">${pro} pro + ${premium} premium</div></div>
    <div class="stat-card"><div class="val blue">${total}</div><div class="lbl">Total Users</div><div class="sub" style="color:#475569">All time registered</div></div>
    <div class="stat-card"><div class="val orange">${pro}</div><div class="lbl">Pro Users</div><div class="sub" style="color:#475569">₹199/mo each</div></div>
    <div class="stat-card"><div class="val purple">${premium}</div><div class="lbl">Premium Users</div><div class="sub" style="color:#475569">₹499/mo each</div></div>
  `;

  // Plan distribution chart
  const maxVal = Math.max(free, pro, premium, 1);
  document.getElementById('plan-chart').innerHTML = `
    <div class="bar-chart">
      <div class="bar-row"><div class="bar-label">Free</div><div class="bar-track"><div class="bar-fill" style="width:${(free/maxVal*100).toFixed(0)}%;background:#475569;"></div></div><div class="bar-val">${free}</div></div>
      <div class="bar-row"><div class="bar-label">Pro</div><div class="bar-track"><div class="bar-fill" style="width:${(pro/maxVal*100).toFixed(0)}%;background:#fb923c;"></div></div><div class="bar-val">${pro}</div></div>
      <div class="bar-row"><div class="bar-label">Premium</div><div class="bar-track"><div class="bar-fill" style="width:${(premium/maxVal*100).toFixed(0)}%;background:#60a5fa;"></div></div><div class="bar-val">${premium}</div></div>
    </div>
    <div style="margin-top:16px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.06);font-size:12px;color:#64748b;">
      Free rate: ${total ? Math.round(free/total*100) : 0}% &nbsp;|&nbsp; Paid: ${total ? Math.round((pro+premium)/total*100) : 0}%
    </div>
  `;

  // Recent signups
  const recent = users.slice(0, 8);
  document.getElementById('recent-signups').innerHTML = recent.length ? recent.map(u => `
    <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
      <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#1B3A6B,#C4622D);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:white;flex-shrink:0;">${(u.full_name||u.email||'?').charAt(0).toUpperCase()}</div>
      <div style="flex:1;min-width:0;"><div style="font-size:13px;font-weight:500;color:#e2e8f0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${u.full_name||'—'}</div><div style="font-size:11px;color:#64748b;overflow:hidden;text-overflow:ellipsis;">${u.email||'—'}</div></div>
      <span class="badge badge-${u.plan||'free'}">${u.plan||'free'}</span>
    </div>`).join('') : '<div style="color:#475569;font-size:13px;">No users yet</div>';

  // Revenue panel
  document.getElementById('revenue-overview').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;justify-content:space-between;padding:12px;background:rgba(52,211,153,0.05);border:1px solid rgba(52,211,153,0.1);border-radius:8px;">
        <span style="font-size:13px;color:#94a3b8;">Monthly Revenue</span>
        <span style="font-size:15px;font-weight:700;color:#34d399;">₹${revenue.toLocaleString('en-IN')}</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:12px;background:rgba(251,146,60,0.05);border:1px solid rgba(251,146,60,0.1);border-radius:8px;">
        <span style="font-size:13px;color:#94a3b8;">Pro Revenue</span>
        <span style="font-size:15px;font-weight:700;color:#fb923c;">₹${(pro*199).toLocaleString('en-IN')}</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:12px;background:rgba(96,165,250,0.05);border:1px solid rgba(96,165,250,0.1);border-radius:8px;">
        <span style="font-size:13px;color:#94a3b8;">Premium Revenue</span>
        <span style="font-size:15px;font-weight:700;color:#60a5fa;">₹${(premium*499).toLocaleString('en-IN')}</span>
      </div>
    </div>
  `;

  // Paying users table
  const paying = users.filter(u => u.plan === 'pro' || u.plan === 'premium');
  document.getElementById('paying-users-table').innerHTML = paying.length ?
    paying.map(u => `<tr>
      <td>${u.full_name||'—'}</td>
      <td style="color:#64748b;">${u.email||'—'}</td>
      <td><span class="badge badge-${u.plan}">${u.plan}</span></td>
      <td style="color:#64748b;">${u.created_at ? new Date(u.created_at).toLocaleDateString('en-IN') : '—'}</td>
      <td>
        <button class="btn-sm" onclick="changePlan('${u.id}','free')">→ Free</button>
        <button class="btn-orange" onclick="changePlan('${u.id}','premium')">→ Premium</button>
      </td>
    </tr>`).join('') :
    '<tr><td colspan="5" style="color:#475569;text-align:center;padding:20px;">No paying users yet</td></tr>';
}

async function loadUsers() {
  renderUsersTable(allUsers.length ? allUsers : await sbGet('profiles', 'select=*&order=created_at.desc'));
}

function renderUsersTable(users) {
  const tbody = document.getElementById('users-table');
  if (!users.length) { tbody.innerHTML = '<tr><td colspan="6" style="color:#475569;text-align:center;padding:20px;">No users found</td></tr>'; return; }
  tbody.innerHTML = users.map(u => `<tr>
    <td><div style="display:flex;align-items:center;gap:8px;">
      <div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#1B3A6B,#C4622D);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:white;">${(u.full_name||u.email||'?').charAt(0).toUpperCase()}</div>
      ${u.full_name||'—'}
    </div></td>
    <td style="color:#64748b;">${u.email||'—'}</td>
    <td><span class="badge badge-${u.plan||'free'}">${u.plan||'free'}</span></td>
    <td><span class="badge ${['admin','super_admin'].includes(u.role) ? 'badge-admin' : ''}" style="${['admin','super_admin'].includes(u.role) ? '' : 'color:#475569'}">${u.role||'user'}</span></td>
    <td style="color:#64748b;">${u.created_at ? new Date(u.created_at).toLocaleDateString('en-IN') : '—'}</td>
    <td>
      <button class="btn-sm" onclick="changePlan('${u.id}','pro')">Pro</button>
      <button class="btn-orange" onclick="changePlan('${u.id}','premium')">Prem</button>
      <button class="btn-sm" onclick="changePlan('${u.id}','free')" style="background:rgba(100,116,139,0.15);color:#94a3b8;border-color:rgba(100,116,139,0.2);">Free</button>
    </td>
  </tr>`).join('');
}

function filterUsers(q) {
  const filtered = allUsers.filter(u => (u.full_name||'').toLowerCase().includes(q.toLowerCase()) || (u.email||'').toLowerCase().includes(q.toLowerCase()));
  renderUsersTable(filtered);
}

async function changePlan(userId, plan) {
  await sbUpdate('profiles', userId, { plan, updated_at: new Date().toISOString() });
  const u = allUsers.find(u => u.id === userId);
  if (u) u.plan = plan;
  renderUsersTable(allUsers);
  showToast(`Plan updated to ${plan}`, 'success');
  loadDashboard();
}

async function grantPlan() {
  const email = document.getElementById('grant-email').value.trim().toLowerCase();
  const plan = document.getElementById('grant-plan').value;
  if (!email) { showToast('Enter an email', 'error'); return; }
  const result = await sbUpdateWhere('profiles', 'email', email, { plan, updated_at: new Date().toISOString() });
  if (!result || !result.length) { showToast('User not found: ' + email, 'error'); return; }
  const idx = allUsers.findIndex(u => u.email === email);
  if (idx > -1) allUsers[idx].plan = plan;
  document.getElementById('grant-email').value = '';
  showToast(`Plan ${plan} granted to ${email}`, 'success');
  loadDashboard();
}

async function grantAdmin() {
  const email = document.getElementById('make-admin-email').value.trim().toLowerCase();
  const role = document.getElementById('make-admin-role').value;
  if (!email) { showToast('Enter an email', 'error'); return; }
  const result = await sbUpdateWhere('profiles', 'email', email, { role, updated_at: new Date().toISOString() });
  if (!result || !result.length) { showToast('User not found: ' + email, 'error'); return; }
  document.getElementById('make-admin-email').value = '';
  showToast(`Role ${role} granted to ${email}`, 'success');
  await loadUsers();
}

async function loadNotifHistory() {
  const notifs = await sbGet('notifications_queue', 'select=*&order=created_at.desc&limit=20');
  const tbody = document.getElementById('notif-history');
  if (!Array.isArray(notifs) || !notifs.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="color:#475569;text-align:center;padding:20px;">No notifications sent yet</td></tr>';
    return;
  }
  tbody.innerHTML = notifs.map(n => `<tr>
    <td style="font-weight:500;">${n.title||'—'}</td>
    <td style="color:#64748b;max-width:200px;overflow:hidden;text-overflow:ellipsis;">${n.body||'—'}</td>
    <td><span class="badge badge-${n.target_plan||'all'}">${n.target_plan||'all'}</span></td>
    <td><span class="badge ${n.status==='sent'?'badge-active':''}">${n.status||'pending'}</span></td>
    <td style="color:#64748b;">${n.created_at ? new Date(n.created_at).toLocaleDateString('en-IN') : '—'}</td>
  </tr>`).join('');
}

async function sendNotif() {
  const title = document.getElementById('notif-title').value.trim();
  const body = document.getElementById('notif-body').value.trim();
  const target = document.getElementById('notif-target').value;
  if (!title || !body) { showToast('Title and body required', 'error'); return; }
  await sbInsert('notifications_queue', { title, body, type: 'broadcast', target_plan: target, status: 'pending' });
  document.getElementById('notif-title').value = '';
  document.getElementById('notif-body').value = '';
  showToast('Notification queued!', 'success');
  await loadNotifHistory();
}

async function loadSystemInfo() {
  const r = await fetch(`${API}/health`).catch(() => null);
  const data = r ? await r.json().catch(() => null) : null;
  document.getElementById('system-info').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:10px;font-size:13px;">
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Backend Status</span><span style="color:${data?.status==='ok'?'#34d399':'#f87171'};font-weight:600;">${data?.status==='ok'?'✓ Online':'✗ Offline'}</span></div>
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Version</span><span style="color:#e2e8f0;">${data?.version||'—'}</span></div>
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Environment</span><span style="color:#e2e8f0;">${data?.env||'—'}</span></div>
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Supabase Admin</span><span style="color:${data?.supabase?'#34d399':'#f87171'};font-weight:600;">${data?.supabase?'✓ Configured':'✗ Missing'}</span></div>
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Razorpay</span><span style="color:${data?.razorpay?'#34d399':'#f87171'};font-weight:600;">${data?.razorpay?'✓ Configured':'✗ Missing'}</span></div>
      <div style="display:flex;justify-content:space-between;"><span style="color:#64748b;">Server Time</span><span style="color:#64748b;font-size:11px;">${data?.timestamp||'—'}</span></div>
    </div>
  `;
}

// ============================================================
// NAVIGATION
// ============================================================
function showPage(page, btn) {
  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  const titles = { dashboard: 'Dashboard', users: 'User Management', plans: 'Plans & Revenue', notifications: 'Notifications', settings: 'Settings' };
  document.getElementById('page-title').textContent = titles[page] || page;
}

// ============================================================
// TOAST
// ============================================================
function showToast(msg, type='') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = 'toast ' + type;
  toast.textContent = msg;
  container.appendChild(toast);
  setTimeout(() => { toast.style.animation = 'toastIn 0.3s ease reverse'; setTimeout(() => toast.remove(), 300); }, 3500);
}

// ============================================================
// ENTER KEY
// ============================================================
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('login-screen').style.display !== 'none') doLogin();
});

// ============================================================
// INIT
// ============================================================
checkSession();
</script>
